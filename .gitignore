# ═══════════════════════════════════════════════════════
#  AIDA — Frontend .gitignore
#  React · Vite · Electron · Tailwind · electron-builder
# ═══════════════════════════════════════════════════════

# ── Dependencies ─────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Vite build output ────────────────────────
dist/
dist-ssr/
.vite/

# ── Electron build output ────────────────────
# electron-builder outputs — rebuilt with:  npm run dist
release/
backend-dist/
build/
out/

# Electron-builder cache
.electron-builder-cache/

# ── Electron Forge (if ever switched) ────────
.webpack/

# ── Local env / secrets ──────────────────────
.env
.env.*
!.env.example
*.env.local

# ── Logs ─────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime cache ────────────────────────────
.cache/
.parcel-cache/
.turbo/

# ── Testing ──────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── TypeScript ───────────────────────────────
*.tsbuildinfo

# ── Editor & OS ──────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── 3D avatar model files (large binaries) ───
public/avatars/*.gltf
public/avatars/*.bin

# ── Storybook (if added later) ───────────────
storybook-static/
.gitignore